snapshot[`entry list --help: snapshot 1`] = `
"
Usage:   timeslip entry list
Version: 0.1.0              

Description:

  List time entries (default: today)

Options:

  -h, --help             - Show this help.                           
  -a, --account  <name>  - Use a specific stored account             
  -j, --json             - Output structured JSON instead of tables  
  -r, --robot            - Output headerless tab-separated values    
  --today                - Show today's entries (default)            
  --from         <date>  - Start date (YYYY-MM-DD)                   
  --to           <date>  - End date (YYYY-MM-DD)                     
  --all                  - Fetch all entries (no date filter)        
  --running              - Show only running timers                  
  --project-id   <id>    - Filter by project ID                      
  --client-id    <id>    - Filter by client ID                       
  --limit        <n>     - Maximum entries to return                 
  --page-size    <n>     - Entries per API page                      

"
`;

