snapshot[`entry --help: snapshot 1`] = `
"
Usage:   timeslip entry
Version: 0.1.0         

Description:

  Manage time entries

Options:

  -h, --help             - Show this help.                           
  -a, --account  <name>  - Use a specific stored account             
  -j, --json             - Output structured JSON instead of tables  
  -r, --robot            - Output headerless tab-separated values    

Commands:

  add                 - Create a time entry               
  update  <entry-id>  - Modify an existing time entry     
  remove  <entry-id>  - Delete a time entry               
  list                - List time entries (default: today)

"
`;

snapshot[`entry add --help: snapshot 1`] = `
"
Usage:   timeslip entry add --project-id <id> --task-id <id> --date <date>
Version: 0.1.0                                                            

Description:

  Create a time entry

Options:

  -h, --help              - Show this help.                                        
  -a, --account  <name>   - Use a specific stored account                          
  -j, --json              - Output structured JSON instead of tables               
  -r, --robot             - Output headerless tab-separated values                 
  --project-id   <id>     - Project ID                                   (required)
  --task-id      <id>     - Task ID                                      (required)
  --date         <date>   - Spent date (YYYY-MM-DD)                      (required)
  --hours        <hours>  - Hours spent (omit to start a running timer)            
  --description  <text>   - Notes for the entry                                    

"
`;

snapshot[`entry update --help: snapshot 1`] = `
"
Usage:   timeslip entry update <entry-id>
Version: 0.1.0                           

Description:

  Modify an existing time entry

Options:

  -h, --help                    - Show this help.                           
  -a, --account        <name>   - Use a specific stored account             
  -j, --json                    - Output structured JSON instead of tables  
  -r, --robot                   - Output headerless tab-separated values    
  --hours              <hours>  - Update hours spent                        
  --description        <text>   - Update notes                              
  --clear-description           - Set description to blank                  
  --date               <date>   - Update spent date (YYYY-MM-DD)            
  --project-id         <id>     - Update project ID                         
  --task-id            <id>     - Update task ID                            

"
`;

snapshot[`entry remove --help: snapshot 1`] = `
"
Usage:   timeslip entry remove <entry-id>
Version: 0.1.0                           

Description:

  Delete a time entry

Options:

  -h, --help             - Show this help.                           
  -a, --account  <name>  - Use a specific stored account             
  -j, --json             - Output structured JSON instead of tables  
  -r, --robot            - Output headerless tab-separated values    

"
`;

